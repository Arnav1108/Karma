# Copy to .env.local and fill in values for local development.

# Base URL of the Karma Advisor API's v1 routes (see karma ai/docs/frontend_contract_plan.md
# section 6). Default assumes `uvicorn api.main:app` running on its default port
# from the `karma ai/` directory.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# One of the server's KARMA_API_KEYS. v1 auth is a static shared key shipped
# to the browser via X-API-Key -- acceptable only for v1's internal/controlled
# audience (frontend_contract_plan.md section 6). Must be replaced by
# per-user auth before any public launch.
NEXT_PUBLIC_API_KEY=

# Also set KARMA_CORS_ORIGINS=http://localhost:3000 on the API server, or the
# browser will block every request (server defaults to an empty allow-list).
